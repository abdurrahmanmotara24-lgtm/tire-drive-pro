# Local dev — copy to `.env` and fill in from Lovable Cloud → Database / project settings.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Vercel (Project → Settings → Environment Variables) — same values for Production + Preview:
#   VITE_SUPABASE_URL
#   VITE_SUPABASE_PUBLISHABLE_KEY
#   SUPABASE_URL              (same URL — server SSR + /api/cloud-public-config)
#   SUPABASE_PUBLISHABLE_KEY  (same key)
#
# Optional: RESEND_API_KEY, LEAD_NOTIFY_EMAIL for lead email notifications
