# Local dev — copy to `.env` and fill in from Lovable Cloud → Database / project settings.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Vercel (Project → Settings → Environment Variables) — same values, for all environments:
# VITE_SUPABASE_URL
# VITE_SUPABASE_PUBLISHABLE_KEY
# SUPABASE_URL          (same as VITE_SUPABASE_URL — for /api routes on the server)
# SUPABASE_PUBLISHABLE_KEY
# Optional: RESEND_API_KEY, LEAD_NOTIFY_EMAIL for lead email notifications
