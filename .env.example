# Local dev only — create .env from this file.
# On Lovable preview: Supabase keys are auto-injected by Cloud (not shown in Secrets; LOVABLE_API_KEY alone is normal).
# Get URL + publishable key from Lovable Cloud tab → Database / project info, or your Supabase dashboard if linked.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
