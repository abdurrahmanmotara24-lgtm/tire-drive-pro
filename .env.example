# Copy to .env for local dev, or set in Lovable Cloud → Secrets.
# Client reads VITE_* or SUPABASE_* (see vite.config envPrefix). Anon key aliases are supported.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Legacy alias (same value as publishable key):
# VITE_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
